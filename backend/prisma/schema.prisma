// ══════════════════════════════════════════════════════
// 1️⃣7️⃣  CUSTOM TESTS — Dedicated Chat-Generator Schema
// ══════════════════════════════════════════════════════

model CustomTest {
  id               String   @id @default(uuid()) @db.Uuid
  user_id          String   @db.Uuid
  subject          String
  class            String?
  chapter          String?
  topic            String?
  difficulty       String   @default("medium")
  num_questions    Int      @default(20)
  duration_minutes Int      @default(30)
  created_at       DateTime @default(now()) @db.Timestamptz

  user      User                 @relation(fields: [user_id], references: [id], onDelete: Cascade)
  questions CustomTestQuestion[]
  attempts  CustomTestAttempt[]
  ai_logs   CustomTestAILog[]

  @@index([user_id])
  @@index([created_at(sort: Desc)])
  @@map("custom_tests")
  @@schema("practice_tests")
}

model CustomTestQuestion {
  id             String   @id @default(uuid()) @db.Uuid
  test_id        String   @db.Uuid
  question_text  String
  option_a       String
  option_b       String
  option_c       String
  option_d       String
  correct_answer String   
  explanation    String?
  difficulty     String   @default("medium")
  created_at     DateTime @default(now()) @db.Timestamptz

  test    CustomTest         @relation(fields: [test_id], references: [id], onDelete: Cascade)
  answers CustomTestAnswer[]

  @@index([test_id])
  @@map("custom_test_questions")
  @@schema("practice_tests")
}

model CustomTestAttempt {
  id           String   @id @default(uuid()) @db.Uuid
  test_id      String   @db.Uuid
  user_id      String   @db.Uuid
  score        Int      @default(0)
  accuracy     Float    @default(0)
  time_taken   Int?     
  submitted_at DateTime @default(now()) @db.Timestamptz

  test    CustomTest         @relation(fields: [test_id], references: [id], onDelete: Cascade)
  user    User               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  answers CustomTestAnswer[]
  analysis CustomTestAnalysis?
  study_plan CustomTestStudyPlan?

  @@index([test_id])
  @@index([user_id])
  @@map("custom_test_attempts")
  @@schema("practice_tests")
}

model CustomTestAnswer {
  id              String  @id @default(uuid()) @db.Uuid
  attempt_id      String  @db.Uuid
  question_id     String  @db.Uuid
  selected_option String? 
  is_correct      Boolean @default(false)

  attempt  CustomTestAttempt  @relation(fields: [attempt_id], references: [id], onDelete: Cascade)
  question CustomTestQuestion @relation(fields: [question_id], references: [id], onDelete: Cascade)

  @@index([attempt_id])
  @@map("custom_test_answers")
  @@schema("practice_tests")
}

model CustomTestAILog {
  id          String   @id @default(uuid()) @db.Uuid
  test_id     String   @db.Uuid
  prompt_used String
  ai_response String
  created_at  DateTime @default(now()) @db.Timestamptz

  test CustomTest @relation(fields: [test_id], references: [id], onDelete: Cascade)


  @@index([test_id])
  @@map("custom_test_ai_logs")
  @@schema("practice_tests")
}

model CustomTestAnalysis {
  id                      String   @id @default(uuid()) @db.Uuid
  attempt_id              String   @db.Uuid @unique
  weak_topics             String[] @default([])
  strong_topics           String[] @default([])
  improvement_suggestions String[] @default([])
  ai_feedback             String
  created_at              DateTime @default(now()) @db.Timestamptz

  attempt CustomTestAttempt @relation(fields: [attempt_id], references: [id], onDelete: Cascade)

  @@map("custom_test_analysis")
  @@schema("practice_tests")
}

// ──────────────────────────────────────
// TRACKER (NCERT PREPARATION SYSTEM)
// ──────────────────────────────────────

enum TrackerStatus {
  pending
  in_progress
  completed

  @@schema("tracker")
}

enum TrackerPriority {
  low
  medium
  high

  @@schema("tracker")
}

enum TrackerActionType {
  status_change
  revision_done
  ncert_done

  @@schema("tracker")
}

model TrackerSubject {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String   @unique @db.VarChar(255)
  created_at DateTime @default(now()) @db.Timestamptz

  chapters      TrackerChapter[]
  user_trackers TrackerUserTracker[]
  custom_topics TrackerCustomTopic[]

  @@map("subjects")
  @@schema("tracker")
}

model TrackerClass {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  class_number Int      @unique
  created_at   DateTime @default(now()) @db.Timestamptz

  chapters      TrackerChapter[]
  user_trackers TrackerUserTracker[]
  custom_topics TrackerCustomTopic[]

  @@map("classes")
  @@schema("tracker")
}

model TrackerChapter {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subject_id     String   @db.Uuid
  class_id       String   @db.Uuid
  chapter_name   String
  chapter_number Int?
  created_at     DateTime @default(now()) @db.Timestamptz

  subject TrackerSubject @relation(fields: [subject_id], references: [id], onDelete: Cascade)
  class   TrackerClass   @relation(fields: [class_id], references: [id], onDelete: Cascade)

  user_trackers TrackerUserTracker[]

  @@unique([subject_id, class_id, chapter_name])
  @@map("chapters")
  @@schema("tracker")
}

model TrackerUserTracker {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id           String  @db.Uuid
  subject_id        String  @db.Uuid
  class_id          String? @db.Uuid
  chapter_id        String? @db.Uuid
  custom_topic_name String?

  status     TrackerStatus @default(pending)
  ncert_read Boolean       @default(false)

  revision1_done Boolean   @default(false)
  revision1_date DateTime? @db.Timestamptz
  revision2_done Boolean   @default(false)
  revision2_date DateTime? @db.Timestamptz
  revision3_done Boolean   @default(false)
  revision3_date DateTime? @db.Timestamptz
  revision4_done Boolean   @default(false)
  revision4_date DateTime? @db.Timestamptz

  last_revised_at DateTime?       @db.Timestamptz
  priority        TrackerPriority @default(medium)

  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz

  user    User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  subject TrackerSubject  @relation(fields: [subject_id], references: [id], onDelete: Cascade)
  class   TrackerClass?   @relation(fields: [class_id], references: [id], onDelete: SetNull)
  chapter TrackerChapter? @relation(fields: [chapter_id], references: [id], onDelete: Cascade)

  logs TrackerLog[]

  @@unique([user_id, chapter_id])
  @@unique([user_id, subject_id, custom_topic_name])
  @@index([user_id])
  @@index([chapter_id])
  @@index([subject_id])
  @@index([class_id])
  @@index([status])
  @@index([last_revised_at])
  @@map("user_tracker")
  @@schema("tracker")
}

model TrackerCustomTopic {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String  @db.Uuid
  subject_id String  @db.Uuid
  class_id   String? @db.Uuid
  topic_name String

  created_at DateTime @default(now()) @db.Timestamptz

  user    User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  subject TrackerSubject @relation(fields: [subject_id], references: [id], onDelete: Cascade)
  class   TrackerClass?  @relation(fields: [class_id], references: [id], onDelete: SetNull)

  @@unique([user_id, subject_id, topic_name])
  @@index([user_id])
  @@map("custom_topics")
  @@schema("tracker")
}

model TrackerLog {
  id          String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String            @db.Uuid
  tracker_id  String            @db.Uuid
  action_type TrackerActionType
  old_value   String?
  new_value   String?

  created_at DateTime @default(now()) @db.Timestamptz

  user    User               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  tracker TrackerUserTracker @relation(fields: [tracker_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([tracker_id])
  @@map("tracker_logs")
  @@schema("tracker")
}

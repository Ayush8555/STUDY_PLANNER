// ══════════════════════════════════════════════════════
// 1️⃣4️⃣  AI CHAT BOT SYSTEM — Dedicated Schema
//     All tables live in ai_chat.* schema
// ══════════════════════════════════════════════════════

model AiChatConversation {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String?  @db.Uuid
  session_id     String?
  started_at     DateTime @default(now()) @db.Timestamptz
  last_active_at DateTime @default(now()) @db.Timestamptz
  is_active      Boolean  @default(true)

  user                  User?                       @relation(fields: [user_id], references: [id], onDelete: SetNull)
  messages              AiChatMessage[]
  prompt_logs           AiChatPromptLog[]
  conversation_metadata AiChatConversationMetadata?

  @@index([user_id])
  @@index([session_id])
  @@index([last_active_at])
  @@map("conversations")
  @@schema("ai_chat")
}

model AiChatMessage {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversation_id String   @db.Uuid
  sender_type     String // 'user' or 'ai'
  message_text    String
  message_type    String // 'text' or 'system'
  created_at      DateTime @default(now()) @db.Timestamptz

  conversation AiChatConversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  ai_response  AiChatAiResponse?
  feedback     AiChatFeedback?

  @@index([conversation_id])
  @@index([created_at])
  @@map("messages")
  @@schema("ai_chat")
}

model AiChatAiResponse {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  message_id       String   @unique @db.Uuid
  response_text    String
  tokens_used      Int?
  model_used       String?
  response_time_ms Int?
  created_at       DateTime @default(now()) @db.Timestamptz

  message AiChatMessage @relation(fields: [message_id], references: [id], onDelete: Cascade)

  @@index([message_id])
  @@map("ai_responses")
  @@schema("ai_chat")
}

model AiChatPromptLog {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversation_id    String   @db.Uuid
  user_input         String
  system_prompt_hash String?
  created_at         DateTime @default(now()) @db.Timestamptz

  conversation AiChatConversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@index([conversation_id])
  @@map("prompt_logs")
  @@schema("ai_chat")
}

model AiChatSecurityLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String?  @db.Uuid
  session_id   String?
  input_text   String
  threat_type  String // e.g., 'prompt_injection', 'data_extraction'
  action_taken String // 'blocked' or 'allowed'
  created_at   DateTime @default(now()) @db.Timestamptz

  user User? @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([session_id])
  @@index([created_at])
  @@map("security_logs")
  @@schema("ai_chat")
}

model AiChatRateLimit {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String?  @db.Uuid
  session_id    String?
  request_count Int      @default(1)
  window_start  DateTime @db.Timestamptz
  created_at    DateTime @default(now()) @db.Timestamptz

  @@index([user_id])
  @@index([session_id])
  @@index([window_start])
  @@map("rate_limits")
  @@schema("ai_chat")
}

model AiChatFeedback {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  message_id    String   @unique @db.Uuid
  user_id       String?  @db.Uuid
  rating        Int? // 1 to 5
  feedback_text String?
  created_at    DateTime @default(now()) @db.Timestamptz

  message AiChatMessage @relation(fields: [message_id], references: [id], onDelete: Cascade)

  @@index([message_id])
  @@index([user_id])
  @@map("feedback")
  @@schema("ai_chat")
}

model AiChatConversationMetadata {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversation_id String   @unique @db.Uuid
  user_agent      String?
  ip_address      String?
  location        String?
  device_type     String?
  created_at      DateTime @default(now()) @db.Timestamptz

  conversation AiChatConversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@index([conversation_id])
  @@map("conversation_metadata")
  @@schema("ai_chat")
}


# ============================================
# STUDY PLANNER - Backend Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# NEVER commit the .env file to git!
# ============================================

# Neon Database URLs
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# Server
PORT=5005
NODE_ENV=development

# JWT (generate a strong random string for production)
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET
JWT_EXPIRES_IN=7d

# Redis
REDIS_URL=redis://localhost:6379

# Google Gemini (get key at https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq (get key at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter (get key at https://openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_api_key_here
